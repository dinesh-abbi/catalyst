{
  "expo": {
    "name": "Catalyst",
    "slug": "uponetraining",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/legacy-icon.png",
    "scheme": "catalyst",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.catalyst.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.catalyst.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/legacy-icon.png",
        "monochromeImage": "./assets/images/adaptive-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "notification": {
        "icon": "./assets/images/adaptive-icon.png"
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/legacy-icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/legacy-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/adaptive-icon.png",
          "sounds": [
            "./assets/notification/appsound.wav"
          ]
        }
      ],
      [
        "expo-font"
      ],
      [
        "@react-native-firebase/app",
        {
          "googleServicesFile": "./android/app/google-services.json"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5af03b1e-6e59-48a5-8415-be05fafeb170"
      }
    },
    "owner": "dineshabbi",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/5af03b1e-6e59-48a5-8415-be05fafeb170"
    }
  }
}